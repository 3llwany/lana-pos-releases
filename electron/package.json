{
  "name": "pos-desktop",
  "version": "1.0.0",
  "description": "POS Desktop Application",
  "main": "main.js",
  "author": "LANA SOFT",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:dir": "electron-builder --dir"
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.pos.desktop",
    "productName": "LANA POS",
    "publish": [
      {
        "provider": "github",
        "owner": "3llwany",
        "repo": "lana-pos-releases"
      }
    ],
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "../dist-electron"
    },
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "../pos.Api/bin/Publish/",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../pos-ui/dist/pos-ui/browser/",
        "to": "frontend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LANA POS"
    }
  }
}
